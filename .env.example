# OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model configuration
OPENAI_MODEL=gpt-4o-mini

# Memory configuration
# Max messages to keep in short-term memory before triggering summarisation
MAX_SHORT_TERM_MESSAGES=20

# Max tokens allowed in context before triggering summarisation
MAX_CONTEXT_TOKENS=8000

# LangGraph checkpointer database path (SQLite)
CHECKPOINT_DB_PATH=./checkpoints.db

# Max number of planning iterations before forced termination
MAX_ITERATIONS=15
